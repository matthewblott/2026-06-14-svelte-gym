{
	"name": "svelte-better-auth-otp",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "bun --bun vite dev",
		"build": "bun --bun vite build"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/kit": "^2.65.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/bun": "^1.3.14",
		"@types/nodemailer": "^8.0.1",
		"better-sqlite3": "^12.11.1",
		"kysely-codegen": "^0.20.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"valibot": "^1.4.2",
		"vite": "^8.0.16"
	},
	"dependencies": {
		"@hotwired/turbo": "^8.0.23",
		"@joemasilotti/bridge-components": "^0.13.2",
		"better-auth": "^1.6.18",
		"change-case": "^5.4.4",
		"kysely": "^0.28.17",
		"nodemailer": "^9.0.3",
		"svelte-better-auth-otp": "."
	},
	"kysely-codegen": {
		"dialect": "sqlite",
		"singularize": true,
		"camelCase": true,
		"outFile": "./src/lib/schema.ts",
		"url": "./storage/main.sqlite3",
		"excludePattern": "{goose_db_version,foreign_keys_view,indexes_view,simple_workouts_view,workouts_view}",
		"overrides": {
			"columns": {
				"exercises.exercise_type": "'cardio' | 'weights'",
				"workout_exercises_view.exercise_type": "'cardio' | 'weights'"
			}
		}
	}
}
